# Copy this to .env and fill in your values.
# Never commit .env to version control!

# ── Discord ───────────────────────────────────────────────────────────────────
# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ── AnimeSchedule Application Token ──────────────────────────────────────────
# From: https://animeschedule.net/users/<your_username>/settings/api
# This is the "Application Token" — used as Bearer token for all standard API calls
# (timetables, shows, etc.) without needing user OAuth2.
ANIMESCHEDULE_APP_TOKEN=your_app_token_here

# ── AnimeSchedule OAuth2 App Credentials ─────────────────────────────────────
# Create an OAuth2 application on the same settings page to get these.
# These are needed so Discord users can authorize their own AnimeSchedule accounts
# (required for OAuth2-only endpoints like /animelists).
ANIMESCHEDULE_CLIENT_ID=your_oauth2_client_id_here
ANIMESCHEDULE_CLIENT_SECRET=your_oauth2_client_secret_here

# ── OAuth2 Redirect URI ───────────────────────────────────────────────────────
# MUST exactly match the redirect URI you registered in your AnimeSchedule app.
# Local dev:  http://localhost:8080/oauth/callback
# Production: https://yourdomain.com/oauth/callback
OAUTH_REDIRECT_URI=http://localhost:8080/oauth/callback

# ── OAuth2 Callback Server Port ───────────────────────────────────────────────
# The port the built-in aiohttp server listens on for OAuth callbacks.
# Default: 8080
OAUTH_CALLBACK_PORT=8080
